# Copy to .env and fill in (Prisma's CLI + the seed script read .env, not .env.local).

# Anthropic API key — powers the free-text AI chat. This is PAY-AS-YOU-GO and is
# NOT the same as a Claude Pro subscription. Get one at https://console.anthropic.com
# The app fully works without it (all engine-driven cards still render); only the
# conversational chat is disabled.
ANTHROPIC_API_KEY=

# Claude model used for the assistant.
ANTHROPIC_MODEL=claude-opus-4-8

# Local SQLite database (no cloud account needed). Swap for a Postgres URL later.
DATABASE_URL="file:./dev.db"

# Single local user id (no auth in the MVP).
DEFAULT_USER_ID=local-user
